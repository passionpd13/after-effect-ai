{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd web && npm install && npm run build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
    "watchPatterns": ["web/**"]
  },
  "deploy": {
    "startCommand": "cd web && PORT=${PORT:-3000} node .next/standalone/server.js",
    "healthcheckPath": "/",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
