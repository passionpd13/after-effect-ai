      "image": {
        "file": "gyeongbokgung_main.png",
        "fit_mode": "cover",
        "position": { "x": "center", "y": "center" },
        "shadow": {
          "enabled": true,
          "color": [0, 0, 0],
          "opacity": 0.6,
          "distance": 12,
          "softness": 20
        }
      },
      "text": {
        "content": "경복궁 근정전",
        "position": "top",
        "animation": "fade_in",
        "delay": 0.5
      },
      "animation": {
        "type": "zoom_in",
        "intensity": "subtle",
        "easing": "ease_in_out"
      },
      "effects": [
        {
          "type": "vignette",
          "params": { "amount": 35 },
          "start_time": 0
