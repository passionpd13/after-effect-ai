      "transition_to_next": {
        "type": "dissolve",
        "duration": 1.5,
        "easing": "ease_out"
      },
      "audio": {
        "sfx": "",
        "sfx_volume": 1.0,
        "narration": "한국 전통 정원은 자연을 거스르지 않고 자연 속에 녹아드는 것을 최고의 아름다움으로 여겼습니다."
      }
    },
    {
      "id": 5,
      "type": "image",
      "duration": 4,
      "image": {
        "file": "sunset_palace.png",
        "fit_mode": "cover",
        "position": { "x": "center", "y": "center" },
        "shadow": {
          "enabled": true,
          "color": [0, 0, 0],
          "opacity": 0.5,
          "distance": 10,
          "softness": 15
        }
      },
      "text": {
        "content": "영원한 아름다움",
        "position": "center",
        "animation": "bounce",
        "delay": 0
      },
      "animation": {
        "type": "zoom_out",
        "intensity": "strong",
        "easing": "ease_out"
      },
      "effects": [
        {
          "type": "lens_flare",
          "params": { "intensity": 0.8, "position": [0.7, 0.3] },
