        {
          "type": "color_correction",
          "params": { "brightness": 1.1, "contrast": 1.15, "saturation": 1.2 },
          "start_time": 0
        }
      ],
      "transition_to_next": {
        "type": "crossfade",
        "duration": 1.5,
        "easing": "ease_in_out"
      },
      "audio": {
        "sfx": "",
        "sfx_volume": 1.0,
        "narration": "조선의 법궁, 경복궁. 600년 역사를 품은 이곳에서 한국 전통 건축의 아름다움을 만나봅니다."
      }
    },
    {
      "id": 2,
      "type": "image",
      "duration": 4,
