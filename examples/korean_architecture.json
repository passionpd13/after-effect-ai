    "created_by": "claude_analysis",
    "version": "1.0"
  },
  "settings": {
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "format": "vertical",
    "background_color": [0.1, 0.1, 0.12],
    "total_duration": 22
  },
  "global_style": {
    "font_family": "Noto Sans KR",
    "title_font_size": 55,
    "subtitle_font_size": 38,
    "text_color": [1, 1, 1],
    "text_stroke": {
      "enabled": true,
      "color": [0, 0, 0],
      "width": 3
    },
    "color_theme": "warm"
  },
  "scenes": [
