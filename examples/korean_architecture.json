      "audio": {
        "sfx": "",
        "sfx_volume": 1.0,
        "narration": "하늘을 향해 부드럽게 휘어 오르는 처마 곡선은 한국 건축만의 독특한 아름다움입니다."
      }
    },
    {
      "id": 4,
      "type": "image",
      "duration": 4.5,
      "image": {
        "file": "garden_pavilion.png",
        "fit_mode": "cover",
        "position": { "x": "center", "y": "center" },
        "shadow": {
          "enabled": false,
          "color": [0, 0, 0],
          "opacity": 0.5,
          "distance": 10,
          "softness": 15
        }
      },
      "text": {
        "content": "자연과의 조화",
        "position": "top",
        "animation": "fade_in",
        "delay": 0.5
      },
      "animation": {
        "type": "float",
        "intensity": "subtle",
        "easing": "ease_in_out"
