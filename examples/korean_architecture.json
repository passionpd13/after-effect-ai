        "file": "dancheong_closeup.png",
        "fit_mode": "cover",
        "position": { "x": "center", "y": "center" },
        "shadow": {
          "enabled": false,
          "color": [0, 0, 0],
          "opacity": 0.5,
          "distance": 10,
          "softness": 15
        }
      },
      "text": {
        "content": "화려한 단청",
        "position": "bottom",
        "animation": "slide_up",
        "delay": 0.3
